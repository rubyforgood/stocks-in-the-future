<%= form_with model: @teacher, url: @teacher.persisted? ? admin_teacher_path(@teacher) : admin_teachers_path, builder: Admin::FormBuilder, class: "space-y-6" do |f| %>
  <div class="bg-white shadow-sm ring-1 ring-gray-900/5 rounded-lg">
    <div class="px-6 py-6">
      <h3 class="text-lg font-medium text-gray-900 mb-6">Teacher Details</h3>

      <%= f.text_field :email,
                       label: "Email",
                       hint: "Also used as the teacher's login username",
                       placeholder: "teacher@example.com" %>

      <%= f.text_field :name,
                       label: "Full Name",
                       hint: "Teacher's full name",
                       placeholder: "John Doe" %>

      <div data-controller="form-filter" data-form-filter-frame-id-value="teacher_classroom_selection">
        <%= f.select :school_id,
                     options_from_collection_for_select(@schools, :id, :name, @selected_school_id),
                     { label: "School Filter", hint: "Select a school to filter the classroom list", include_blank: "All Schools" },
                     { name: "school_id", data: { action: "change->form-filter#change" } } %>
      </div>

      <%= turbo_frame_tag "teacher_classroom_selection", class: "block mb-6" do %>
        <% if @classrooms.any? %>
          <%= f.collection_check_boxes :classroom_ids,
                                       @classrooms,
                                       :id,
                                       :name,
                                       label: "Classrooms",
                                       hint: "Select one or more classrooms to assign to this teacher",
                                       wrapper_class: "mb-0" %>
        <% else %>
          <div class="mb-6">
            <label class="block text-sm font-medium text-gray-700 mb-2">Classrooms</label>
            <div class="bg-yellow-50 border border-yellow-200 rounded-md p-4">
              <div class="flex">
                <div class="flex-shrink-0">
                  <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                  </svg>
                </div>
                <div class="ml-3">
                  <h3 class="text-sm font-medium text-yellow-800">No Classrooms Available</h3>
                  <p class="text-sm text-yellow-700 mt-1">
                    No Classrooms associated with this school and active year, please
                    <%= link_to "update classrooms", admin_classrooms_path, class: "font-medium underline text-yellow-700 hover:text-yellow-600" %>
                    so they will show up here.
                  </p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      <% end %>

      <% if @teacher.new_record? %>
        <div class="mt-6 pt-6 border-t border-gray-200">
          <p class="text-sm text-gray-600">
            <i class="fas fa-info-circle mr-1"></i>
            A temporary password will be generated and a password reset email will be sent to the teacher's email address.
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex items-center justify-between gap-x-4">
    <div class="flex items-center gap-x-4">
      <%= f.cancel_button "Cancel", url: @teacher.persisted? ? admin_teacher_path(@teacher) : admin_teachers_path %>
      <%= f.submit_button @teacher.persisted? ? "Update Teacher" : "Create Teacher" %>
    </div>
    <% if @teacher.discarded? %>
      <%= link_to "Permanently Delete",
                  admin_teacher_path(@teacher),
                  data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to permanently delete this teacher? This action cannot be undone." },
                  class: "inline-flex items-center px-4 py-2 border border-red-300 shadow-sm text-sm font-medium rounded-md text-red-700 bg-white hover:bg-red-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500" %>
    <% end %>
  </div>
<% end %>
